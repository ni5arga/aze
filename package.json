{
  "name": "aze",
  "version": "0.1.0",
  "description": "Modular WhatsApp bot built on Baileys",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "baileys": "^7.0.0-rc.9",
    "dotenv": "^16.4.5",
    "jimp": "^1.6.1",
    "link-preview-js": "^3.2.0",
    "pino": "^9.6.0",
    "pino-pretty": "^11.2.2",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "wa-sticker-formatter": "^4.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
